---
import Layout from "./Layout.astro";
import ContentWrapper from "../components/ContentWrapper.astro";
import { AUTHOR_LOCALE, AUTHOR_TIME_ZONE, SITE_NAME, BLOG_POST_DEFAULT_DESCRIPTION } from "../config/site.mjs";
import { base } from "astro:config/server";

const { frontmatter } = Astro.props;
const pageTitle = frontmatter?.title ? `${frontmatter.title} | ${SITE_NAME}` : `Blog Post | ${SITE_NAME}`;
const pageDescription = frontmatter?.description ?? BLOG_POST_DEFAULT_DESCRIPTION;
const tags: string[] = [];

if (Array.isArray(frontmatter?.tags)) {
  for (const rawTag of frontmatter.tags) {
    if (typeof rawTag === "string" && rawTag.trim().length > 0) {
      tags.push(rawTag);
    }
  }
}
const displayPubDate = frontmatter?.pubDate
  ? new Date(frontmatter.pubDate).toLocaleDateString(AUTHOR_LOCALE, {
      year: "numeric",
      month: "long",
      day: "numeric",
      timeZone: AUTHOR_TIME_ZONE,
    })
  : null;

type PostFrontmatter = {
  title?: string;
  pubDate?: string;
};

type PostModule = {
  frontmatter?: PostFrontmatter;
};

const postModules = import.meta.glob("../pages/posts/*.md", { eager: true });
const currentSlug = Astro.url.pathname.split("/").filter(Boolean).pop() ?? "";

const orderedPosts = Object.entries(postModules)
  .map(([path, mod]) => {
    const typedModule = mod as PostModule;
    const slug = path.split("/").pop()?.replace(".md", "") ?? "";
    const parsedDate = typedModule.frontmatter?.pubDate ? new Date(typedModule.frontmatter.pubDate) : new Date(0);

    return {
      slug,
      title: typedModule.frontmatter?.title ?? slug,
      pubDate: parsedDate,
    };
  })
  .sort((a, b) => {
    const timeDiff = a.pubDate.getTime() - b.pubDate.getTime();
    if (timeDiff !== 0) return timeDiff;
    return a.slug.localeCompare(b.slug);
  });

const currentIndex = orderedPosts.findIndex((post) => post.slug === currentSlug);
const previousPost = currentIndex > 0 ? orderedPosts[currentIndex - 1] : null;
const nextPost = currentIndex >= 0 && currentIndex < orderedPosts.length - 1
  ? orderedPosts[currentIndex + 1]
  : null;
---

<Layout title={pageTitle} description={pageDescription}>
  <ContentWrapper>
    <article class="post-content">
      <header class="mb-8 border-b border-neutral-200 dark:border-neutral-800 pb-4">
        {frontmatter?.title && (
          <h1 class="text-4xl font-extrabold text-sky-700 dark:text-sky-200">{frontmatter.title}</h1>
        )}
        {frontmatter?.pubDate && (
          <p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400">
            Published on: {displayPubDate}
          </p>
        )}
        {tags.length > 0 && (
          <ul class="mt-4 flex flex-wrap gap-2" aria-label="Post tags">
            {tags.map((tag) => (
              <li class="bg-sky-100 text-sky-800 dark:bg-sky-900/50 dark:text-sky-200 text-xs font-medium px-3 py-1 rounded-full">
                {tag}
              </li>
            ))}
          </ul>
        )}
      </header>

      <slot />

      {(previousPost || nextPost) && (
        <nav class="mt-10 flex items-center justify-between gap-4 border-t border-neutral-200 dark:border-neutral-800 pt-6" aria-label="Post navigation">
          <div class="w-10">
            {previousPost ? (
              <a
                href={`${base}posts/${previousPost.slug}`}
                class="post-nav-link inline-flex h-10 w-10 items-center justify-center rounded-full border border-neutral-300 dark:border-neutral-700 transition-colors"
                aria-label={`Previous post: ${previousPost.title}`}
                title={previousPost.title}
              >
                <i class="fas fa-chevron-left text-sm" aria-hidden="true"></i>
              </a>
            ) : (
              <span></span>
            )}
          </div>

          <div class="w-10 text-right">
            {nextPost ? (
              <a
                href={`${base}posts/${nextPost.slug}`}
                class="post-nav-link inline-flex h-10 w-10 items-center justify-center rounded-full border border-neutral-300 dark:border-neutral-700 transition-colors"
                aria-label={`Next post: ${nextPost.title}`}
                title={nextPost.title}
              >
                <i class="fas fa-chevron-right text-sm" aria-hidden="true"></i>
              </a>
            ) : (
              <span></span>
            )}
          </div>
        </nav>
      )}
    </article>
  </ContentWrapper>
</Layout>

<style>
  .post-content {
    color: rgb(38 38 38);
    line-height: 1.8;
  }

  :global(.dark) .post-content {
    color: rgb(212 212 212);
  }

  .post-content :global(h1),
  .post-content :global(h2),
  .post-content :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-weight: 700;
    line-height: 1.25;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    color: rgb(3 105 161);
  }

  :global(.dark) .post-content :global(h2) {
    color: rgb(125 211 252);
  }

  .post-content :global(p),
  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 1rem 0;
  }

  .post-content :global(a) {
    color: rgb(3 105 161);
    text-decoration: underline;
  }

  .post-content :global(.post-nav-link) {
    color: rgb(82 82 82);
    text-decoration: none;
  }

  .post-content :global(.post-nav-link:hover) {
    color: rgb(23 23 23);
    background-color: rgb(245 245 245);
  }

  :global(.dark) .post-content :global(.post-nav-link) {
    color: rgb(212 212 212);
  }

  :global(.dark) .post-content :global(.post-nav-link:hover) {
    color: rgb(250 250 250);
    background-color: rgb(38 38 38);
  }

  :global(.dark) .post-content :global(a) {
    color: rgb(125 211 252);
  }
</style>
