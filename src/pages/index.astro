---
import Layout from '../layouts/Layout.astro';

const identity = {
  firstName: "Francisco",
  middleName: "Abraham",
  lastName: "Perez",
  profession: "Computer Engineer",
  workAreasInterest: ["game development"],
};
---
<Layout
  title="AbrahamPrz | Home"
  description="Abraham's personal website."
>
  <div class="bg-white text-neutral-900 dark:bg-neutral-900 dark:text-white flex-1 flex flex-col">
    <main class="flex flex-1 flex-col items-center justify-center text-center px-4">
      
      <h1 class="text-5xl md:text-6xl font-extrabold text-sky-700 dark:text-sky-200 mb-2">
        {identity.middleName} {identity.lastName}
      </h1>
      <p class="text-lg text-neutral-700 dark:text-slate-200 max-w-xl mb-8">
        {identity.profession} interested in {identity.workAreasInterest.join(", ")}.
      </p>
    </main>
  </div>
</Layout>
