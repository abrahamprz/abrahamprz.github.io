---
import Layout from '../layouts/Layout.astro';
import ContentWrapper from '../components/ContentWrapper.astro';
import { base } from 'astro:config/server';
import { AUTHOR_LOCALE, AUTHOR_TIME_ZONE, SITE_NAME, BLOG_PAGE_TITLE, BLOG_PAGE_DESCRIPTION } from '../config/site.mjs';

const title = BLOG_PAGE_TITLE;
const intro = "Welcome to my not-so-serious blog, a space on the internet where I share updates on my projects and personal life.";
const postModules = import.meta.glob('./posts/*.md', { eager: true });

type PostFrontmatter = {
  title?: string;
  description?: string;
  pubDate?: string;
  tags?: unknown[];
};

type PostModule = {
  frontmatter?: PostFrontmatter;
};

const sortOptions = {
  newest: { label: 'Newest to oldest' },
  oldest: { label: 'Oldest to newest' },
};

const posts = Object.entries(postModules)
  .map(([path, mod]) => {
    const slug = path.split('/').pop()?.replace('.md', '') ?? '';
    const typedModule = mod as PostModule;
    const frontmatter = typedModule.frontmatter ?? {};
    const parsedPubDate = frontmatter.pubDate ? new Date(frontmatter.pubDate) : new Date(0);
    const tags = Array.isArray(frontmatter.tags)
      ? frontmatter.tags.filter((tag): tag is string => typeof tag === 'string' && tag.trim().length > 0)
      : [];
    return {
      slug,
      title: frontmatter.title ?? slug,
      description: frontmatter.description ?? '',
      pubDate: parsedPubDate,
      tags,
      displayDate: parsedPubDate.toLocaleDateString(AUTHOR_LOCALE, {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
        timeZone: AUTHOR_TIME_ZONE,
      }),
    };
  })
  .sort((a, b) => {
    const timeDiff = b.pubDate.getTime() - a.pubDate.getTime();
    if (timeDiff !== 0) return timeDiff;
    return a.slug.localeCompare(b.slug);
  });
---
<Layout
  title={`${SITE_NAME} | ${BLOG_PAGE_TITLE}`}
  description={BLOG_PAGE_DESCRIPTION}
>
  <ContentWrapper>
    <h1 class="text-4xl font-extrabold text-sky-700 dark:text-sky-200 mb-2">
      {title}
    </h1>
    <p class="text-lg text-neutral-700 dark:text-slate-300"> 
      {intro}
    </p> 
    
    <hr class="my-8 border-0 border-t border-neutral-200 dark:border-neutral-700" />

    {posts.length > 0 ? (
      <>
        <div class="mb-6 flex justify-end">
          <button
            id="sort-toggle"
            type="button"
            data-order="newest"
            data-sort-options={JSON.stringify(sortOptions)}
            class="inline-flex items-center gap-2 rounded-md border border-neutral-300 dark:border-neutral-700 px-3 py-2 text-sm font-medium text-neutral-700 dark:text-neutral-200 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors"
            aria-label="Sort posts by date"
          >
            <span id="sort-label">{sortOptions.newest.label}</span>
            <i id="sort-arrow" class="fas fa-arrow-down text-xs" aria-hidden="true"></i>
          </button>
        </div>

        <ul id="post-list" class="space-y-6">
        {posts.map((post) => (
          <li
            data-post-item
            data-timestamp={post.pubDate.getTime()}
            data-slug={post.slug}
          >
            <a
              href={base + 'posts/' + post.slug}
              class="block p-6 border border-neutral-200 dark:border-neutral-800 rounded-lg hover:shadow-lg hover:bg-slate-50 dark:hover:bg-neutral-800/50 transition-all duration-300"
            >
              <h2 class="text-2xl font-semibold text-sky-700 dark:text-sky-300">
                {post.title}
              </h2>
              <p class="text-sm text-neutral-500 dark:text-neutral-400 mt-1">
                {post.displayDate}
              </p>
              {post.description && (
                <p class="text-neutral-700 dark:text-neutral-300 mt-3">
                  {post.description}
                </p>
              )}
              {post.tags.length > 0 && (
                <ul class="mt-4 flex flex-wrap gap-2" aria-label="Post tags">
                  {post.tags.map((tag) => (
                    <li class="bg-sky-100 text-sky-800 dark:bg-sky-900/50 dark:text-sky-200 text-xs font-medium px-3 py-1 rounded-full">
                      {tag}
                    </li>
                  ))}
                </ul>
              )}
            </a>
          </li>
        ))}
        </ul>
      </>
    ) : (
      <div class="mt-16 text-center text-neutral-500 dark:text-neutral-400">
        <i class="fas fa-pencil-alt fa-3x"></i>
        <p class="mt-4 text-xl">No posts yet.</p>
      </div>
    )}

    <script>
      const postList = document.getElementById('post-list');
      const sortToggle = document.getElementById('sort-toggle');
      const sortLabel = document.getElementById('sort-label');
      const sortArrow = document.getElementById('sort-arrow');

      if (postList && sortToggle && sortLabel && sortArrow) {
        const list = postList;
        const toggle = sortToggle;
        const label = sortLabel;
        const arrow = sortArrow;
        const options = JSON.parse(toggle.getAttribute('data-sort-options') ?? '{}');
        const postItems = Array.from(list.querySelectorAll('[data-post-item]'));

        function applySort() {
          const order = toggle.getAttribute('data-order') === 'oldest' ? 'oldest' : 'newest';
          const sortedItems = [...postItems].sort((a, b) => {
            const aTime = Number(a.getAttribute('data-timestamp') ?? 0);
            const bTime = Number(b.getAttribute('data-timestamp') ?? 0);
            if (aTime !== bTime) {
              return order === 'oldest' ? aTime - bTime : bTime - aTime;
            }

            const aSlug = a.getAttribute('data-slug') ?? '';
            const bSlug = b.getAttribute('data-slug') ?? '';
            return order === 'oldest'
              ? aSlug.localeCompare(bSlug)
              : bSlug.localeCompare(aSlug);
          });

          sortedItems.forEach((item) => list.appendChild(item));
          label.textContent = options[order]?.label ?? options.newest?.label ?? 'Newest to oldest';
          arrow.className = order === 'oldest'
            ? 'fas fa-arrow-up text-xs'
            : 'fas fa-arrow-down text-xs';
          toggle.setAttribute('aria-label', `Sort posts by date: ${label.textContent}`);
          toggle.setAttribute('data-order', order);
        }

        toggle.addEventListener('click', () => {
          const currentOrder = toggle.getAttribute('data-order') ?? 'newest';
          const nextOrder = currentOrder === 'newest' ? 'oldest' : 'newest';
          toggle.setAttribute('data-order', nextOrder);
          applySort();
        });

        toggle.setAttribute('data-order', 'newest');
        applySort();
      }
    </script>
  </ContentWrapper>
</Layout>
